{
  "name": "wrkflw",
  "version": "1.2.2",
  "description": "Code-first orchestration across local and SSH Claude Code and Codex agents",
  "keywords": [
    "agents",
    "claude-code",
    "codex",
    "orchestration",
    "workflow"
  ],
  "homepage": "https://github.com/tomrford/wrkflw#readme",
  "bugs": "https://github.com/tomrford/wrkflw/issues",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tomrford/wrkflw.git"
  },
  "bin": {
    "wrkflw": "dist/cli.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "check": "bun run format:check && bun run lint && bun run typecheck && bun run test && bun run docs:check && bun run build",
    "docs:check": "tsx scripts/check-docs.ts",
    "format": "oxfmt .",
    "format:check": "oxfmt --check .",
    "lint": "oxlint --deny-warnings .",
    "prepack": "bun run build",
    "test": "tsx --test test/**/*.test.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "0.3.201",
    "@anthropic-ai/sdk": "0.93.0",
    "@modelcontextprotocol/sdk": "1.29.0",
    "@openai/codex-sdk": "0.143.0",
    "@standard-schema/spec": "1.1.0",
    "tsx": "4.23.0",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@types/node": "26.1.0",
    "oxfmt": "0.58.0",
    "oxlint": "1.73.0",
    "typescript": "6.0.3"
  },
  "engines": {
    "node": ">=22"
  },
  "packageManager": "bun@1.3.13"
}
